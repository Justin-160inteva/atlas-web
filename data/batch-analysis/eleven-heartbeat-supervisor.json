{
  "schemaVersion": 6,
  "id": "eleven-runtime-heartbeat-supervisor-v6-dynamic-current-batch",
  "enabled": true,
  "configurationRevision": "dynamic-queue-persistent-retry-20260722-01",
  "manifest": "data/batch-analysis/eleven-pilot-scan-manifest.json",
  "trigger": "data/batch-analysis/eleven-pilot-v2-trigger.json",
  "runtimeProgress": "data/runtime-progress/eleven-pilot-progress.json",
  "dictionary": "data/scan-bug-dictionary.json",
  "reportOutput": "data/batch-analysis/eleven-heartbeat-supervisor-state.json",
  "workflow": "scan-eleven-pilot-v2.yml",
  "staleAfterSeconds": 90,
  "hardStaleAfterSeconds": 180,
  "resumeCooldownSeconds": 60,
  "maximumQueueItems": 11,
  "policy": {
    "checkEveryMinutes": 5,
    "oneItemPerRun": true,
    "maximumConcurrentDownloads": 1,
    "automaticContinuationAfterDurableSuccess": true,
    "automaticRedispatchAfterTechnicalFailure": true,
    "retryTechnicalFailuresUntilResolved": true,
    "maximumAttemptsPerItem": 20,
    "durableStateAlwaysWins": true,
    "terminalProjectionRequired": true,
    "deduplicateResumeRequests": true,
    "runtimeOrConfigRepairsOnly": true,
    "neverModifyExecutableSourceAutomatically": true,
    "neverBroadenAuthorization": true,
    "neverRetainOriginalMedia": true,
    "neverExpandQueueScope": true,
    "protectedFailuresStopRedispatch": true
  }
}
