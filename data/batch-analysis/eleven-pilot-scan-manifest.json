  "authorizationId": "auth-eleven-game-world-20260719",
  "catalog": "data/eleven-game-world-ac-shadows-catalog.json",
  "queue": "data/batch-analysis/eleven-pilot-scan-queue.json",
  "statusOutput": "data/batch-analysis/eleven-pilot-scan-status.json",
  "analyzer": "tools/analyze_authorized_video_v14.py",
  "outputPrefix": "eleven",
  "maximumQueueItems": 1,
  "maxItemsPerRun": 1,
  "maximumConcurrentDownloads": 1,
  "autoContinueAfterDurableSuccess": true,
  "maxSamplesA": 480,
  "maxSamplesDefault": 360,
  "minimumIntervalSeconds": 3.0,
  "perItemTimeoutSeconds": 6300,
  "pilotRegion": "最终单期 P80",
  "processingOrder": "strict-p080-only",
  "productionOrderPolicy": "data/batch-analysis/eleven-production-order-policy.json",
  "preferPublicApi": true,
  "refreshSourceMetadata": true,
  "downloadBackoffSeconds": 20,
  "forceTranscodeFallback": true,
  "maxAttemptsPerItem": 20,
  "staleRunningAfterSeconds": 7200,
  "runtimeHeartbeat": {
    "enabled": true,
    "publishDownloadStageImmediately": true,
    "publishTerminalAnalyzerState": true,
    "preserveLastMeasuredDownloadTelemetry": true,
    "minimumIntervalSeconds": 30,
    "independentTicker": true,
    "continuesDuringNetworkStall": true,
    "publicSanitizedProgressOnly": true
  },
  "downloadTelemetry": {
    "enabled": true,
    "intervalSeconds": 30,
    "speedMode": "rolling-30-second-window",
    "fields": ["downloadedBytes","totalBytes","speedBytesPerSecond","averageSpeedBytesPerSecond","segmentIndex","segmentCount","segmentDownloadedBytes","segmentTotalBytes","etaSeconds","downloadElapsedSeconds","speedWindowSeconds","stalledSeconds","heartbeatSequence","transferMode","maxRangeWorkers","telemetryMeasuredAt","telemetryPreserved"]
  },
  "downloadOptimization": {
    "noArtificialRateLimit": true,
    "adaptiveParallelRanges": false,
    "maxRangeWorkers": 4,
    "parallelRangeThresholdBytes": 8388608,
    "chunkSizeBytes": 2097152,
    "rangeRetries": 3,
    "rangeRetriesPerCdn": 2,
    "heartbeatSeconds": 20,
    "speedWindowSeconds": 30,
    "fallbackToResumableSingleStream": true,
    "preferBackupUrlOnRepeated412": true,
    "metadataRefreshPasses": 2,
    "analysisVideoMaxHeight": 480,
    "allowLegacyProgressiveFallback": true,
    "bypassPublicVideoWebpage": true,
    "preservePartialAcrossCdnCandidates": true,
    "cdnSpeedProbeEnabled": true,
    "cdnSpeedProbeCandidates": 4,
    "cdnSpeedProbeBytes": 524288,
    "cdnSpeedProbeTimeoutSeconds": 6,
    "preferRangeCapableCdn": true
  },
  "analysisOptimization": {
    "policy": "catalog-aware-quality-speed-balance",
    "classAQualitySamples": 480,
    "classBHighUtilitySamples": 360,
    "classBBalancedSamples": 300,
    "classCFastReviewSamples": 180,
    "descriptorResolution": "320x180",
    "preserveNumericDescriptorSchema": true,
    "qualityFloor": "retain route, scene-change, color, edge, motion and perceptual-hash descriptors"
  },
  "compatibilityFixes": {
    "curlCffiResponseContextManager": true,
    "adaptiveRangeResume": true,
    "preserveDownloadTelemetryAcrossStages": true,
    "wbiSignedPlayerMetadata": true,
    "verifiedCatalogCidFirst": true,
    "apiProvidedCdnRotation": true,
    "publicVideoWebpageBypassed": true,
    "fastestAuthorizedCdnProbe": true,
    "preferRangeCapableCdn": true,
    "ffmpegLargeProbeWindow": true,
    "generatedTimestampRecovery": true,
    "pixelFormatNormalization": true,
    "implausibleFrameRateNormalization": true,
    "emptyStreamCopyFallback": true,
    "fixedBy": "tools/analyze_authorized_video_v14.py"
  },
  "recoveryPolicy": {
    "enabled": true,
    "maxAttemptsPerItem": 20,
    "automaticallyRetryKnownTransientFailures": true,
    "retryTechnicalFailuresUntilResolved": true,
    "fastCooldownCapSeconds": 60,
    "minimumSafeCooldownSeconds": 5,
    "blockUnknownOrIdentityFailures": false,
    "protectedFailureCategories": ["authorization","identity","privacy","queue-scope","retention"],
    "neverModifySourceCodeAutomatically": false,
    "neverBroadenAuthorization": true,
    "neverRetainOriginalMedia": true
  },
  "retention": {
    "originalVideo": false,
    "framePixels": false,
    "numericDescriptorsOnly": true
  },
  "autonomousRepairPolicy": "data/scan-autonomy-policy.json",
  "autonomousRepairConfirmationRequired": false,
  "batchInitializedAt": "2026-07-23T02:30:00Z"
}
