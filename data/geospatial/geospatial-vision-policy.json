{
  "schemaVersion": 2,
  "release": "0.9.4.8",
  "enabled": true,
  "provider": "github-models",
  "endpoint": "https://models.github.ai/inference/chat/completions",
  "models": [
    "openai/gpt-4.1",
    "openai/gpt-4o-mini"
  ],
  "reviewerPools": [
    {
      "id": "reasoning-reviewer",
      "models": [
        "openai/gpt-4.1",
        "openai/gpt-4.1-mini"
      ],
      "minimumCompleteReviewers": 1
    },
    {
      "id": "vision-reviewer",
      "models": [
        "openai/gpt-4o-mini"
      ],
      "minimumCompleteReviewers": 1
    }
  ],
  "request": {
    "temperature": 0.0,
    "maximumOutputTokens": 1600,
    "timeoutSeconds": 75,
    "maximumAttempts": 1,
    "maximumRetryAfterSeconds": 20,
    "delayBetweenRequestsSeconds": 2,
    "eventsPerRequest": 3,
    "framesPerEvent": 1
  },
  "confirmation": {
    "requireTwoModelConsensus": true,
    "minimumConfidencePerModel": 0.92,
    "allowedEvidenceTypes": [
      "direct_popup_text",
      "direct_map_label",
      "unique_highlight_with_readable_text"
    ],
    "requireObservedLabel": true,
    "requireCandidateIdFromStageOne": true,
    "requireUniqueLocationAssignment": true,
    "maximumConfirmedSlotsThisBatch": 14
  },
  "privacy": {
    "imagesMayBeSentToAuthorizedModelDuringWorkflow": true,
    "imagesMayBeCommittedToRepository": false,
    "originalVideoMayBeCommittedToRepository": false,
    "deleteAllTransientPixelsBeforeJobExit": true,
    "persistOnlyTextHashesTimestampsAndCoordinates": true
  },
  "safety": {
    "numericDescriptorsAloneCannotConfirmLocation": true,
    "modelGuessWithoutReadableEvidenceMustRemainUnresolved": true,
    "duplicateCandidateAssignmentsMustRemainUnresolved": true,
    "modelDisagreementMustRemainUnresolved": true,
    "contactSheetCrossEventLeakageMustRemainUnresolved": true,
    "fallbackModelMustRemainIndependentFromOtherReviewerPool": true
  }
}
